# Backend API URL — copy this file to .env and fill in your values
# Simulator:       http://localhost:3001
# Physical device: http://YOUR_LOCAL_IP:3001  (find IP: ipconfig getifaddr en0)
# Production:      update RAILWAY_BACKEND_URL in lib/api.ts with your Railway URL
EXPO_PUBLIC_BACKEND_URL=http://localhost:3001

# Stripe publishable key (from https://dashboard.stripe.com/apikeys)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
