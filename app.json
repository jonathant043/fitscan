{
  "expo": {
    "name": "FitScan",
    "slug": "fitscan",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",

    "icon": "./assets/icon.png",
    "entryPoint": "./node_modules/expo-router/entry",

    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#060d1a"
    },

    "assetBundlePatterns": [
      "**/*"
    ],

    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fitscan.app",
      "buildNumber": "1.0.0"
    },

    "android": {
      "package": "com.fitscan.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#020817"
      }
    },

    "web": {
      "bundler": "metro",
      "favicon": "./assets/icon.png"
    },

    "plugins": [
      "expo-router",
      "expo-camera",
      ["@stripe/stripe-react-native", { "merchantIdentifier": "merchant.com.fitscan.app" }]
    ],

    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "YOUR-EAS-PROJECT-ID"
      }
    }
  }
}
